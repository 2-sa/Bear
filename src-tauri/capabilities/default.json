{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities",
  "windows": ["main", "harbor-pip", "harbor-browser", "harbor-modal-overlay"],
  "permissions": [
    "core:default",
    "os:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "core:window:allow-set-decorations",
    "core:window:allow-set-icon",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-current-monitor",
    "core:window:allow-outer-size",
    "core:window:allow-outer-position",
    "core:webview:allow-set-webview-zoom",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*/**" },
        { "url": "http://*:*/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:default",
    "deep-link:default",
    "updater:default",
    "process:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-create",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$CACHE/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$AUDIO/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$AUDIO/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$AUDIO/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$AUDIO/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$AUDIO/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$AUDIO/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    }
  ]
}
